import streamlit as st
import os
import sys

# Make sure the application directory is in the path
app_dir = os.path.dirname(os.path.abspath(__file__))
if app_dir not in sys.path:
    sys.path.append(app_dir)

# Use the consolidated schema manager for initialization
from src.db_schema_manager import SchemaManager

def initialize_database():
    """Initialize the database using the consolidated schema manager"""
    schema_manager = SchemaManager()
    schema_manager.init_migration_table()
    schema_manager.apply_migrations()
    schema_manager.ensure_all_tables()
    schema_manager.validate_schema()
    print("Database initialization complete")

if __name__ == "__main__":
    # Initialize database first
    initialize_database()
    
    # Then import and run the main file
    os.system(f"{sys.executable} -m streamlit run {os.path.join(app_dir, 'src', 'app.py')}")
